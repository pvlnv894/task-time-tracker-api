<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.tasktimetrackerapi.mapper.TaskMapper">
    <select id="selectById" parameterType="Long" resultType="org.example.tasktimetrackerapi.model.Task">
        select *
        from tasks
        where id = #{value}
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id" parameterType="org.example.tasktimetrackerapi.model.Task">
        insert into tasks(name, description, status)
        values(#{name}, #{description}, #{status})
    </insert>
    <update id="updateById" parameterType="org.example.tasktimetrackerapi.model.Task">
        update tasks
        set name = #{name},
            description = #{description},
            status = #{status}
            where id = #{id}
    </update>
</mapper>